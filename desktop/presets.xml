<?xml version="1.0" encoding="UTF-8"?>
<presets>
  <preset name="Test">
    <oscillator waveform="sine" gain="1.33"/>
    <oscillator waveform="square" gain="0.5"/>
    <filter mode="lowpass" cutoff_hz="800" resonance_q="0.707"/>
    <vibrato rate_hz="6" depth_cents="50"/>
    <envelope attack_seconds="0.05" decay_seconds="0.2" sustain_level="0.7" release_seconds="0.8"/>
  </preset>
  <preset name="Square">
    <oscillator waveform="square" gain="1"/>
    <envelope attack_seconds="0.05" decay_seconds="0.2" sustain_level="0.65" release_seconds="0.4"/>
  </preset>
  <preset name="Triangle">
    <oscillator waveform="triangle" gain="1"/>
    <envelope attack_seconds="0.08" decay_seconds="0.2" sustain_level="0.75" release_seconds="0.5"/>
  </preset>
  <preset name="Sawtooth">
    <oscillator waveform="sawtooth" gain="1"/>
    <filter mode="lowpass" cutoff_hz="6000" resonance_q="0.707"/>
    <envelope attack_seconds="0.03" decay_seconds="0.25" sustain_level="0.65" release_seconds="0.4"/>
  </preset>
  <preset name="Warm">
    <oscillator waveform="triangle" gain="0.7"/>
    <oscillator waveform="sine" gain="0.3"/>
    <filter mode="lowpass" cutoff_hz="2500" resonance_q="0.707"/>
    <vibrato rate_hz="5" depth_cents="12"/>
    <tremolo rate_hz="4" depth="0.2"/>
    <envelope attack_seconds="0.02" decay_seconds="0.5" sustain_level="0.7" release_seconds="0.6"/>
  </preset>
  <preset name="Classical Piano">
    <oscillator waveform="sine" gain="0.78"/>
    <oscillator waveform="triangle" gain="0.22"/>
    <filter mode="lowpass" cutoff_hz="1900" resonance_q="0.5"/>
    <reverb room_size="0.64" damping="0.75" mix="0.16"/>
    <envelope attack_seconds="0.015" decay_seconds="1.3" sustain_level="0.02" release_seconds="0.9"/>
  </preset>
</presets>
